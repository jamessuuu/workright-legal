---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import CTASection from "../components/CTASection.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
import ReviewSchema from "../components/schema/ReviewSchema.astro";
import Breadcrumb from "../components/SiteBreadcrumb.astro";
import { firmData } from "../data/firm";
import { getCollection } from "astro:content";

const testimonials = await getCollection("testimonials");
const sorted = testimonials.sort((a, b) => b.data.rating - a.data.rating);
const featured = sorted[0];
const rest = sorted.slice(1);

const avgRating = (testimonials.reduce((sum, t) => sum + t.data.rating, 0) / testimonials.length).toFixed(1);

const reviewData = testimonials.map((t) => ({
  name: t.data.name,
  rating: t.data.rating,
  practiceArea: t.data.practiceArea,
  content: t.body || "",
}));
---

<BaseLayout
  title="Client Testimonials | WorkRight Legal | Sydney Employment Lawyers"
  description="Read what our clients say about working with WorkRight Legal. Real feedback from employees we've helped with unfair dismissal, discrimination, and other workplace matters."
>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: firmData.url },
      { name: "Testimonials", url: `${firmData.url}/testimonials` },
    ]}
  />
  <ReviewSchema reviews={reviewData} />

  <Hero
    heading="What our clients say"
    subheading="Real feedback from real employees we've represented."
    variant="page"
  />

  <Breadcrumb
    items={[
      { name: "Home", url: firmData.url },
      { name: "Testimonials", url: `${firmData.url}/testimonials` },
    ]}
  />

  <!-- Aggregate rating -->
  <section class="py-10 border-b border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="flex items-center justify-center gap-5">
        <span class="text-5xl font-bold tracking-tight" style="font-family: var(--font-heading);">
          {avgRating}
        </span>
        <div>
          <div class="flex items-center gap-1 mb-1">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg class:list={["w-5 h-5", i < Math.round(Number(avgRating)) ? "text-[var(--color-accent)]" : "text-[var(--color-border)]"]} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-sm text-[var(--color-text-secondary)]">
            Based on {testimonials.length} client reviews
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured testimonial -->
  {featured && (
    <section class="py-16 lg:py-24">
      <div class="max-w-3xl mx-auto px-5 sm:px-8 lg:px-10 reveal">
        <TestimonialCard
          name={featured.data.name}
          rating={featured.data.rating}
          practiceArea={featured.data.practiceArea}
          content={featured.body || ""}
          featured={true}
        />
      </div>
    </section>
  )}

  <!-- Remaining testimonials -->
  <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {rest.map((t) => (
          <TestimonialCard
            name={t.data.name}
            rating={t.data.rating}
            practiceArea={t.data.practiceArea}
            content={t.body || ""}
          />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to become our next success story?"
    subheading="Contact us today for a free, confidential consultation."
  />
</BaseLayout>
