---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/CTASection.astro";
import BreadcrumbSchema from "../../components/schema/BreadcrumbSchema.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import PersonSchema from "../../components/schema/PersonSchema.astro";
import { firmData, practiceAreasList } from "../../data/firm";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const attorneys = await getCollection("attorneys");
  return attorneys.map((attorney) => ({
    params: { slug: attorney.data.slug },
    props: { attorney },
  }));
}

const { attorney } = Astro.props;
const { data } = attorney;
const { Content } = await render(attorney);

const testimonials = await getCollection("testimonials");
const clientStories = testimonials.slice(0, 3);

const firstName = data.name.split(" ")[0];
---

<BaseLayout title={data.metaTitle} description={data.metaDescription}>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: firmData.url },
      { name: "Team", url: `${firmData.url}/team` },
      { name: data.name, url: `${firmData.url}/team/${data.slug}` },
    ]}
  />
  <PersonSchema
    name={data.name}
    title={data.title}
    description={data.philosophy}
    image={data.image}
    url={`${firmData.url}/team/${data.slug}`}
    credentials={data.credentials}
  />

  <section class="pt-28 lg:pt-36 pb-10">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <Breadcrumb
        items={[
          { name: "Home", url: firmData.url },
          { name: "Team", url: `${firmData.url}/team` },
          { name: data.name, url: `${firmData.url}/team/${data.slug}` },
        ]}
      />
    </div>
  </section>

  <!-- Hero section with photo + key info -->
  <section class="py-16 lg:py-24">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16 items-start">
        <div class="reveal">
          <div class="aspect-[3/4] rounded-xl overflow-hidden bg-[var(--color-surface-muted)]">
            <Image
              src={data.image}
              alt={`${data.name}, ${data.title} at WorkRight Legal`}
              class="w-full h-full object-cover"
              width={600}
              height={800}
              loading="eager"
              format="webp"
            />
          </div>
        </div>

        <div class="lg:col-span-2 reveal-delay-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-8 bg-[var(--color-accent)]"></div>
            <span class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-text-tertiary)]">{data.title}</span>
          </div>

          <h1
            class="text-3xl lg:text-5xl font-bold tracking-tight"
            style="font-family: var(--font-heading);"
          >
            {data.name}
          </h1>

          <blockquote class="mt-6 text-lg text-[var(--color-text-secondary)] italic leading-relaxed border-l-2 border-[var(--color-accent)] pl-5">
            &ldquo;{data.philosophy}&rdquo;
          </blockquote>

          <div class="mt-8 grid grid-cols-2 gap-6">
            <div>
              <p class="text-sm text-[var(--color-text-tertiary)] font-medium uppercase tracking-wider mb-1">Experience</p>
              <p class="text-base font-semibold">{data.yearsExperience}+ years</p>
            </div>
            <div>
              <p class="text-sm text-[var(--color-text-tertiary)] font-medium uppercase tracking-wider mb-1">Location</p>
              <p class="text-base font-semibold">Sydney, NSW</p>
            </div>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/contact" class="btn btn-primary text-sm">Book Consultation</a>
            <a href={`mailto:${firmData.email}`} class="btn btn-outline text-sm">Email {firstName}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bio content -->
  <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="prose max-w-none reveal"
      >
        <Content />
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="py-16 lg:py-20 bg-[var(--color-surface-alt)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="reveal">
          <h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-tertiary)] mb-5">Education & Qualifications</h2>
          <ul class="space-y-3">
            {data.credentials.map((c: string) => (
              <li class="flex items-start gap-3 text-base text-[var(--color-text-secondary)]">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
                {c}
              </li>
            ))}
          </ul>
        </div>

        <div class="reveal-delay-1">
          <h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-tertiary)] mb-5">Bar Admissions</h2>
          <ul class="space-y-3">
            {data.barAdmissions.map((b: string) => (
              <li class="flex items-start gap-3 text-base text-[var(--color-text-secondary)]">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
                {b}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice areas -->
  <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <h2
          class="text-2xl font-bold tracking-tight"
          style="font-family: var(--font-heading);"
        >
          Areas of practice
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 stagger-children">
        {practiceAreasList.map((area) => (
          <a
            href={`/services/${area.slug}`}
            class="flex items-center gap-3 p-4 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-accent)] transition-colors group"
          >
            <span class="text-base font-medium group-hover:text-[var(--color-accent)] transition-colors">{area.name}</span>
            <svg class="w-3.5 h-3.5 ml-auto text-[var(--color-text-tertiary)] group-hover:text-[var(--color-accent)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Client testimonials -->
  {clientStories.length > 0 && (
    <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
        <div class="flex items-center gap-3 mb-8">
          <div class="h-px w-8 bg-[var(--color-accent)]"></div>
          <h2
            class="text-2xl font-bold tracking-tight"
            style="font-family: var(--font-heading);"
          >
            What clients say
          </h2>
        </div>
        <div class="space-y-6 stagger-children">
          {clientStories.map((t) => (
            <blockquote class="border border-[var(--color-border)] rounded-xl p-6 lg:p-8">
              <div class="flex gap-0.5 mb-4">
                {Array.from({ length: t.data.rating }).map(() => (
                  <svg class="w-4 h-4 text-[var(--color-accent)]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-base text-[var(--color-text-secondary)] leading-relaxed italic">{t.body}</p>
              <footer class="mt-4">
                <span class="text-base font-medium">{t.data.name}</span>
                <span class="text-sm text-[var(--color-text-tertiary)] ml-2">{t.data.practiceArea}</span>
              </footer>
            </blockquote>
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href="/testimonials" class="btn btn-outline text-sm">View all testimonials</a>
        </div>
      </div>
    </section>
  )}

  <CTASection
    heading={`Ready to discuss your case with ${firstName}?`}
    subheading="Book a free, confidential consultation today."
  />
</BaseLayout>
