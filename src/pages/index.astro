---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PracticeAreaCard from "../components/PracticeAreaCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import CTASection from "../components/CTASection.astro";
import VideoSection from "../components/VideoSection.astro";
import ImageSection from "../components/ImageSection.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import FAQSchema from "../components/schema/FAQSchema.astro";
import AnimatedCounter from "../components/AnimatedCounter.astro";
import { firmData, practiceAreasList } from "../data/firm";
import { getCollection } from "astro:content";

const testimonials = await getCollection("testimonials");
const testimonialData = testimonials.map((t) => ({
  ...t,
  renderedBody: t.body || "",
}));

const homeFaqs = [
  {
    question: "Do I need an employment lawyer, or can I handle my case myself?",
    answer: "While you can represent yourself at the Fair Work Commission, employment law is complex and employers almost always have legal representation. Having a specialist employment lawyer significantly improves your chances of a favourable outcome. At WorkRight Legal, we offer a free initial consultation so you can understand your options before deciding."
  },
  {
    question: "How much does it cost to hire an employment lawyer in Sydney?",
    answer: "At WorkRight Legal, your initial consultation is always free. For eligible unfair dismissal and general protections cases, we offer no win, no fee arrangements. For other matters such as contract review, we offer transparent fixed fees. We'll always discuss costs upfront so there are no surprises."
  },
  {
    question: "What is the most common type of employment law case in Australia?",
    answer: "Unfair dismissal is the most common employment law claim in Australia, with over 15,000 applications lodged with the Fair Work Commission each year. Other common cases include workplace bullying, discrimination, general protections claims, and disputes over redundancy and severance pay."
  },
  {
    question: "How long does an employment law case typically take?",
    answer: "Timelines vary depending on the type of case. Unfair dismissal claims typically resolve within 3 to 6 months. Workplace discrimination matters may take 6 to 12 months. Contract disputes can often be resolved within weeks. During your free consultation, we'll give you a realistic timeline for your specific situation."
  },
  {
    question: "Can I make a claim if I've already resigned from my job?",
    answer: "Yes, in some circumstances. If you were forced to resign due to intolerable working conditions, known as constructive dismissal, you may still be able to lodge an unfair dismissal claim. You may also have grounds for a general protections claim if your workplace rights were violated. Contact us within 21 days of your resignation for the best chance of success."
  },
];
---

<BaseLayout
  title="WorkRight Legal | Sydney Employment Lawyers | Free Consultation"
  description="Sydney's specialist employment lawyers. Unfair dismissal, workplace discrimination, contract review. Free initial consultation. No win, no fee options. Call (02) 9555 1234."
>
  <!-- Hero -->
  <Hero
    heading="Protecting employee rights across Greater Sydney"
    subheading="Specialist employment lawyers dedicated exclusively to workers. Free initial consultation for all employment matters."
    ctaText="Get Started"
    ctaLink="/contact"
    secondaryCtaText={`Call ${firmData.phone}`}
    secondaryCtaLink={`tel:${firmData.phoneClean}`}
    variant="home"
  />

  <!-- Animated stats -->
  <section class="py-14 lg:py-20 border-b border-[var(--color-border)] bg-[var(--color-surface-alt)]">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-16">
        <AnimatedCounter value="15+" label="Years Experience" />
        <AnimatedCounter value="95%" label="Success Rate" />
        <AnimatedCounter value="500+" label="Clients Helped" />
        <AnimatedCounter value="$0" label="Initial Consultation" />
      </div>
    </div>
  </section>

  <!-- Hero image -->
  <section class="py-16 lg:py-24">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="reveal-scale">
        <div class="overflow-hidden rounded-2xl aspect-[21/9] bg-[var(--color-surface-muted)] shadow-xl">
          <img
            src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1400&h=600&fit=crop&q=80"
            alt="Modern Sydney office interior with harbour views"
            class="w-full h-full object-cover"
            width="1400"
            height="600"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Credibility badges -->
  <section class="py-10 lg:py-14 border-y border-[var(--color-border-subtle)]">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] text-center mb-6">Memberships & Recognition</p>
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-4 text-sm text-[var(--color-text-secondary)] font-medium">
        <span class="flex items-center gap-3">
          <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent)]"></span>
          Law Society of NSW
        </span>
        <span class="flex items-center gap-3">
          <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent)]"></span>
          NSW Bar Association
        </span>
        <span class="flex items-center gap-3">
          <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent)]"></span>
          Industrial Relations Society of NSW
        </span>
        <span class="flex items-center gap-3">
          <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent)]"></span>
          Australian Lawyers Alliance
        </span>
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section class="py-24 lg:py-32">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="max-w-2xl mb-16 reveal">
        <div class="flex items-center gap-4 mb-5">
          <div class="h-[1.5px] w-10 accent-line"></div>
          <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)]">Services</span>
        </div>
        <h2
          class="text-3xl lg:text-[3rem] font-bold tracking-tight leading-[1.08]"
          style="font-family: var(--font-heading);"
        >
          How we can help
        </h2>
        <p class="mt-5 text-lg text-[var(--color-text-secondary)] leading-relaxed">
          We focus exclusively on employment law. Specialist expertise that general practice firms can't match.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {practiceAreasList.map((area, i) => (
          <PracticeAreaCard
            title={area.name}
            description={area.shortDescription}
            iconKey={area.iconKey}
            slug={area.slug}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Featured image + text "Why Us" -->
  <section class="py-24 lg:py-32 section-warm">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-center">
        <div class="reveal">
          <div class="overflow-hidden rounded-2xl aspect-[4/3] bg-[var(--color-surface-muted)] shadow-lg">
            <img
              src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=800&h=600&fit=crop&q=80"
              alt="Professional handshake in modern office setting"
              class="w-full h-full object-cover"
              width="800"
              height="600"
              loading="lazy"
            />
          </div>
        </div>
        <div class="reveal-delay-1">
          <div class="flex items-center gap-4 mb-5">
            <div class="h-[1.5px] w-10 accent-line"></div>
            <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)]">Why Us</span>
          </div>
          <h2
            class="text-3xl lg:text-[2.75rem] font-bold tracking-tight leading-[1.08]"
            style="font-family: var(--font-heading);"
          >
            We only represent employees
          </h2>
          <p class="mt-6 text-lg text-[var(--color-text-secondary)] leading-relaxed">
            Unlike general practice firms that represent both sides, we exclusively advocate for workers. This means no conflicts of interest, deeper specialist knowledge, and a genuine passion for protecting your rights.
          </p>
          <div class="mt-10 space-y-4">
            {["15+ years focused on employment law", "Hundreds of successful cases", "Direct access to your lawyer", "No win, no fee for eligible cases"].map((item) => (
              <div class="flex items-center gap-4">
                <div class="w-6 h-6 rounded-full bg-[var(--color-accent)] flex items-center justify-center shrink-0">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </div>
                <span class="text-[var(--color-text)] font-medium">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 lg:py-32">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <div class="reveal lg:sticky lg:top-28">
          <div class="flex items-center gap-4 mb-5">
            <div class="h-[1.5px] w-10 accent-line"></div>
            <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)]">Process</span>
          </div>
          <h2
            class="text-3xl lg:text-[3rem] font-bold tracking-tight leading-[1.08]"
            style="font-family: var(--font-heading);"
          >
            Three steps to resolution
          </h2>
          <p class="mt-5 text-lg text-[var(--color-text-secondary)] leading-relaxed">
            We make the legal process simple and stress-free.
          </p>
          <div class="mt-10">
            <div class="overflow-hidden rounded-2xl aspect-[4/3] bg-[var(--color-surface-muted)] shadow-lg">
              <img
                src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=800&h=600&fit=crop&q=80"
                alt="Legal consultation in a modern office"
                class="w-full h-full object-cover"
                width="800"
                height="600"
                loading="lazy"
              />
            </div>
          </div>
        </div>

        <div class="space-y-12 stagger-children">
          {[
            { num: "01", title: "Free initial call", desc: "Tell us about your situation. We'll assess your case and explain your options. No obligation, completely confidential." },
            { num: "02", title: "Strategic assessment", desc: "We conduct a thorough legal analysis, identify the strongest path forward, and develop a tailored strategy." },
            { num: "03", title: "Expert representation", desc: "We handle everything, from preparing your application to representing you in negotiations, conciliation, or hearings." },
          ].map((step) => (
            <div class="group">
              <div class="flex items-start gap-6">
                <span class="text-4xl font-bold text-gradient tracking-tight" style="font-family: var(--font-heading);">{step.num}</span>
                <div>
                  <h3 class="text-xl lg:text-2xl font-semibold tracking-tight" style="font-family: var(--font-heading);">
                    {step.title}
                  </h3>
                  <p class="mt-3 text-base lg:text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-lg">{step.desc}</p>
                </div>
              </div>
              <div class="mt-8 h-px bg-[var(--color-border)]"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <VideoSection
    heading="See how we work"
    subheading="A brief introduction to WorkRight Legal and our approach to employment law."
    videoId="ntHRtf0GK8A"
    posterUrl="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1280&h=720&fit=crop&q=80"
  />

  <!-- Testimonials -->
  <section class="py-24 lg:py-32 section-warm">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="max-w-2xl mb-16 reveal">
        <div class="flex items-center gap-4 mb-5">
          <div class="h-[1.5px] w-10 accent-line"></div>
          <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)]">Testimonials</span>
        </div>
        <h2
          class="text-3xl lg:text-[3rem] font-bold tracking-tight leading-[1.08]"
          style="font-family: var(--font-heading);"
        >
          What our clients say
        </h2>
        <p class="mt-5 text-lg text-[var(--color-text-secondary)] leading-relaxed">
          Real experiences from real people we've helped.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {testimonialData.map((t, i) => (
          <TestimonialCard
            name={t.data.name}
            rating={t.data.rating}
            practiceArea={t.data.practiceArea}
            content={t.renderedBody}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <FAQSchema faqs={homeFaqs} />
  <section class="py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 lg:px-12">
      <div class="mb-12 reveal">
        <div class="flex items-center gap-4 mb-5">
          <div class="h-[1.5px] w-10 accent-line"></div>
          <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)]">FAQ</span>
        </div>
        <h2
          class="text-3xl lg:text-[3rem] font-bold tracking-tight leading-[1.08]"
          style="font-family: var(--font-heading);"
        >
          Common questions
        </h2>
      </div>
      <FAQAccordion faqs={homeFaqs} />
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    heading="Ready to discuss your case?"
    subheading="Contact us today for a free, confidential consultation with a specialist employment lawyer."
  />
</BaseLayout>
