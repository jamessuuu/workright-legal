---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import ProcessSteps from "../../../components/ProcessSteps.astro";
import FAQAccordion from "../../../components/FAQAccordion.astro";
import ServiceAreaGrid from "../../../components/ServiceAreaGrid.astro";
import CTASection from "../../../components/CTASection.astro";
import UrgencyBanner from "../../../components/UrgencyBanner.astro";
import ExitIntentModal from "../../../components/ExitIntentModal.astro";
import BreadcrumbSchema from "../../../components/schema/BreadcrumbSchema.astro";
import LegalServiceSchema from "../../../components/schema/LegalServiceSchema.astro";
import FAQSchema from "../../../components/schema/FAQSchema.astro";
import HowToSchema from "../../../components/schema/HowToSchema.astro";
import { firmData, practiceAreasList } from "../../../data/firm";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const areas = await getCollection("practiceAreas");
  return areas.map((area) => ({
    params: { slug: area.data.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const { data } = area;
const { Content } = await render(area);

const allTestimonials = await getCollection("testimonials");
const pageTestimonials = allTestimonials.filter(
  (t) => t.data.practiceArea === data.title
);

// Urgency banners for time-sensitive practice areas
const urgencyData: Record<string, { days: number; message: string }> = {
  "unfair-dismissal-lawyers-sydney": {
    days: 21,
    message: "You have 21 days from dismissal to lodge your claim. Do not wait.",
  },
  "general-protections-lawyers-sydney": {
    days: 21,
    message: "General protections claims must be lodged within 21 days. Act now.",
  },
};
const urgency = urgencyData[data.slug];
---

<BaseLayout title={data.metaTitle} description={data.metaDescription}>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: firmData.url },
      { name: "Services", url: `${firmData.url}/services` },
      { name: data.title, url: `${firmData.url}/services/${data.slug}` },
    ]}
  />
  <LegalServiceSchema
    name={`${data.title} - ${firmData.name}`}
    description={data.description}
    url={`${firmData.url}/services/${data.slug}`}
    serviceAreas={data.serviceAreas}
  />
  <FAQSchema faqs={data.faqs} />
  <HowToSchema
    name={`How to make a ${data.title.toLowerCase()} claim`}
    description={`Step-by-step process for ${data.title.toLowerCase()} cases with WorkRight Legal, Sydney employment lawyers.`}
    steps={data.process}
  />

  <Hero
    heading={data.heroHeading}
    subheading={data.heroSubheading}
    ctaText="Get Free Case Assessment"
    ctaLink="/contact"
    secondaryCtaText={`Call ${firmData.secondaryPhone}`}
    secondaryCtaLink={`tel:${firmData.secondaryPhoneClean}`}
    variant="practice"
    showStats={true}
    stats={data.stats}
  />

  {urgency && (
    <UrgencyBanner days={urgency.days} message={urgency.message} />
  )}

  <Breadcrumb
    items={[
      { name: "Home", url: firmData.url },
      { name: "Services", url: `${firmData.url}/services` },
      { name: data.title, url: `${firmData.url}/services/${data.slug}` },
    ]}
  />

  <!-- Key Facts -->
  <section class="py-14 border-b border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-tertiary)] mb-6">Key Facts</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 stagger-children">
        {data.keyFacts.map((fact: string) => (
          <div class="flex items-start gap-3 p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)]">
            <svg class="w-4 h-4 text-[var(--color-accent)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{fact}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="prose prose-lg prose-neutral max-w-none reveal
        prose-headings:font-[var(--font-heading)] prose-headings:tracking-tight prose-headings:font-semibold
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-p:text-[var(--color-text-secondary)] prose-p:leading-relaxed prose-p:mb-6
        prose-li:text-[var(--color-text-secondary)]
        prose-a:text-[var(--color-text)] prose-a:underline prose-a:underline-offset-4 prose-a:decoration-[var(--color-border)]"
      >
        <Content />
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <span class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-text-tertiary)]">Process</span>
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-10" style="font-family: var(--font-heading);">
        Our {data.title.toLowerCase()} process
      </h2>
      <ProcessSteps steps={data.process} />
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 lg:py-20 bg-[var(--color-surface-alt)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="flex items-center gap-3 mb-8">
        <div class="h-px w-8 bg-[var(--color-accent)]"></div>
        <span class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-text-tertiary)]">FAQ</span>
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-8" style="font-family: var(--font-heading);">
        Frequently asked questions
      </h2>
      <FAQAccordion faqs={data.faqs} />
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10 reveal">
      <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-4" style="font-family: var(--font-heading);">
        {data.title} lawyers across Sydney
      </h2>
      <p class="text-base text-[var(--color-text-secondary)] mb-6">
        Serving clients across Greater Sydney and surrounding areas within 100km of the CBD.
      </p>
      <ServiceAreaGrid areas={data.serviceAreas} />
    </div>
  </section>

  <!-- Client Testimonials -->
  {pageTestimonials.length > 0 && (
    <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10 reveal">
        <div class="flex items-center gap-3 mb-8">
          <div class="h-px w-8 bg-[var(--color-accent)]"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-text-tertiary)]">Client Stories</span>
        </div>
        <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-10" style="font-family: var(--font-heading);">
          What our clients say
        </h2>
        <div class="space-y-6">
          {pageTestimonials.map((testimonial) => (
            <blockquote class="border border-[var(--color-border)] rounded-xl p-6 lg:p-8">
              <div class="flex gap-0.5 mb-4">
                {Array.from({ length: testimonial.data.rating }).map(() => (
                  <svg class="w-4 h-4 text-[var(--color-accent)]" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-base text-[var(--color-text-secondary)] leading-relaxed italic">{testimonial.body}</p>
              <footer class="mt-4 text-base font-medium">{testimonial.data.name}</footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Practice Areas -->
  <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10 reveal">
      <h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-tertiary)] mb-6">Related Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {practiceAreasList
          .filter((a) => a.slug !== data.slug)
          .slice(0, 4)
          .map((area) => (
            <a
              href={`/services/${area.slug}`}
              class="block p-5 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:shadow-sm transition-all group"
            >
              <span class="text-sm font-semibold group-hover:text-[var(--color-accent)] transition-colors">{area.name}</span>
              <p class="mt-1.5 text-xs text-[var(--color-text-tertiary)] leading-relaxed line-clamp-2">{area.shortDescription}</p>
              <span class="inline-flex items-center gap-1 mt-3 text-xs font-medium text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity">
                Learn more
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </a>
          ))}
      </div>
    </div>
  </section>

  <CTASection heading={data.ctaText} subheading="Contact us today for a free, confidential assessment of your case." />

  {urgency && (
    <ExitIntentModal days={urgency.days} practiceArea={data.title} />
  )}
</BaseLayout>
