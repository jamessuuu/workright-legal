---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CTASection from "../components/CTASection.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { firmData } from "../data/firm";
import { getCollection } from "astro:content";

const attorneys = await getCollection("attorneys");
---

<BaseLayout
  title="Our Team | WorkRight Legal | Sydney Employment Lawyers"
  description="Meet the legal team at WorkRight Legal. Specialist employment lawyers with 15+ years experience protecting employee rights across Sydney."
>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: firmData.url },
      { name: "Team", url: `${firmData.url}/team` },
    ]}
  />

  <Hero
    heading="Our team"
    subheading="Specialist employment lawyers committed to protecting your rights."
    variant="page"
  />

  <Breadcrumb
    items={[
      { name: "Home", url: firmData.url },
      { name: "Team", url: `${firmData.url}/team` },
    ]}
  />

  <section class="py-20 lg:py-28">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="max-w-2xl mb-16 reveal">
        <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed">
          At WorkRight Legal, every client works directly with their lawyer. We believe in specialist focus over general practice, personal attention over volume, and genuine advocacy over transaction.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {attorneys.map((attorney) => (
          <a
            href={`/team/${attorney.data.slug}`}
            class="group block rounded-xl border border-[var(--color-border)] overflow-hidden card-hover"
          >
            <div class="aspect-[3/4] overflow-hidden bg-[var(--color-surface-muted)]">
              <img
                src={attorney.data.image}
                alt={`${attorney.data.name}, ${attorney.data.title}`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                width="600"
                height="800"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h2
                class="text-xl font-semibold tracking-tight group-hover:text-[var(--color-accent)] transition-colors"
                style="font-family: var(--font-heading);"
              >
                {attorney.data.name}
              </h2>
              <p class="text-base text-[var(--color-text-tertiary)] mt-1">{attorney.data.title}</p>
              <p class="text-base text-[var(--color-text-secondary)] mt-3 leading-relaxed line-clamp-2">
                {attorney.data.philosophy}
              </p>
              <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent)] opacity-0 group-hover:opacity-100 translate-x-[-4px] group-hover:translate-x-0 transition-all duration-300">
                View profile
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to speak with a specialist?"
    subheading="Book a free, confidential consultation with our team."
  />
</BaseLayout>
