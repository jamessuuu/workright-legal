---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/SiteBreadcrumb.astro";
import CTASection from "../../components/CTASection.astro";
import BreadcrumbSchema from "../../components/schema/BreadcrumbSchema.astro";
import ArticleSchema from "../../components/schema/ArticleSchema.astro";
import { Prose } from "@/components/starwind/prose";
import { Badge } from "@/components/starwind/badge";
import { firmData } from "../../data/firm";
import { getCollection, render } from "astro:content";

// Map author names to their team page slugs
const authorSlugMap: Record<string, { slug: string; title: string }> = {
  "Sarah Mitchell": { slug: "sarah-mitchell", title: "Principal Lawyer" },
  "James Chen": { slug: "james-chen", title: "Senior Associate" },
  "Priya Sharma": { slug: "priya-sharma", title: "Associate" },
};

export async function getStaticPaths() {
  const posts = await getCollection("news");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

// Get related articles (all posts except current, max 2)
const allPosts = await getCollection("news");
const relatedPosts = allPosts
  .filter((p) => p.data.slug !== data.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);

const formattedDate = new Date(data.date).toLocaleDateString("en-AU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout title={data.metaTitle} description={data.metaDescription} ogType="article">
  <div class="article-progress-bar" aria-hidden="true"></div>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: firmData.url },
      { name: "News", url: `${firmData.url}/news` },
      { name: data.title, url: `${firmData.url}/news/${data.slug}` },
    ]}
  />
  <ArticleSchema
    title={data.title}
    description={data.description}
    url={`${firmData.url}/news/${data.slug}`}
    datePublished={data.date}
    authorName={data.author}
    image={data.image}
    wordCount={wordCount}
  />

  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <Breadcrumb
        items={[
          { name: "Home", url: firmData.url },
          { name: "News", url: `${firmData.url}/news` },
          { name: data.title, url: `${firmData.url}/news/${data.slug}` },
        ]}
      />

      <div class="mt-6">
        <div class="flex items-center gap-3 mb-4">
          <Badge variant="ghost" size="sm" class="bg-[var(--color-accent-subtle)] text-[var(--color-accent)] uppercase tracking-wider">
            {data.category}
          </Badge>
          <span class="text-xs text-[var(--color-text-tertiary)]">{formattedDate}</span>
          <span class="text-xs text-[var(--color-text-tertiary)]">&middot; {readingTime} min read</span>
        </div>

        <h1
          class="text-3xl lg:text-4xl font-bold tracking-tight leading-tight"
          style="font-family: var(--font-heading);"
        >
          {data.title}
        </h1>

        <p class="mt-4 text-lg text-[var(--color-text-secondary)] leading-relaxed">
          {data.description}
        </p>

        <div class="mt-6 flex items-center gap-3 pb-8 border-b border-[var(--color-border)]">
          <div>
            {authorSlugMap[data.author] ? (
              <a href={`/team/${authorSlugMap[data.author].slug}`} class="text-sm font-medium hover:text-[var(--color-accent)] transition-colors">{data.author}</a>
            ) : (
              <span class="text-sm font-medium">{data.author}</span>
            )}
            <p class="text-xs text-[var(--color-text-tertiary)]">{authorSlugMap[data.author]?.title ?? "Lawyer"}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {data.image && (
    <section class="pb-10">
      <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
        <div class="overflow-hidden rounded-xl aspect-video bg-[var(--color-surface-muted)]">
          <Image
            src={data.image}
            alt={data.title}
            class="w-full h-full object-cover"
            width={800}
            height={450}
            loading="eager"
            format="webp"
          />
        </div>
      </div>
    </section>
  )}

  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <Prose class="max-w-none site-prose">
        <Content />
      </Prose>
    </div>
  </section>

  <!-- Back to News + Related Articles -->
  <section class="py-16 lg:py-20 border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-5 sm:px-8 lg:px-10">
      <a href="/news" class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors mb-10">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m7-7-7 7 7 7" />
        </svg>
        Back to all articles
      </a>

      {relatedPosts.length > 0 && (
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-tertiary)] mb-6">More from WorkRight Legal</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {relatedPosts.map((related) => (
              <a
                href={`/news/${related.data.slug}`}
                class="group block rounded-xl border border-[var(--color-border)] overflow-hidden card-hover"
              >
                {related.data.image && (
                  <div class="aspect-video overflow-hidden bg-[var(--color-surface-muted)]">
                    <Image
                      src={related.data.image}
                      alt={related.data.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                      width={400}
                      height={225}
                      loading="lazy"
                      format="webp"
                    />
                  </div>
                )}
                <div class="p-4">
                  <Badge variant="ghost" size="sm" class="bg-[var(--color-accent-subtle)] text-[var(--color-accent)] uppercase tracking-wider">{related.data.category}</Badge>
                  <h3 class="mt-1.5 text-base font-semibold tracking-tight group-hover:text-[var(--color-accent)] transition-colors leading-snug" style="font-family: var(--font-heading);">
                    {related.data.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <CTASection heading="Need legal advice?" subheading="Contact us for a free, confidential consultation about your situation." />
</BaseLayout>
