---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ContactForm from "../components/ContactForm";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
import { firmData } from "../data/firm";
---

<BaseLayout
  title="Contact WorkRight Legal | Free Consultation | Sydney Employment Lawyers"
  description="Contact WorkRight Legal for a free 30-minute employment law consultation. Level 12, 123 Pitt Street, Sydney. Call (02) 9555 1234."
  hideMobileCTA={true}
>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: firmData.url },
      { name: "Contact", url: `${firmData.url}/contact` },
    ]}
  />

  <Hero
    heading="Get in touch"
    subheading="Free 30-minute consultation to discuss your case and explore your options."
    variant="page"
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <h2 class="text-xl font-semibold tracking-tight mb-6" style="font-family: var(--font-heading);">
            Send us an enquiry
          </h2>
          <ContactForm client:visible />
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 reveal-delay-1">
          <div class="rounded-xl border border-[var(--color-border)] p-7 space-y-5">
            <h3 class="font-semibold text-sm" style="font-family: var(--font-heading);">Contact information</h3>

            <div class="space-y-4 text-sm">
              <div>
                <p class="text-[var(--color-text-tertiary)] text-xs font-medium uppercase tracking-wider mb-1">Phone</p>
                <a href={`tel:${firmData.phoneClean}`} class="font-medium">{firmData.phone}</a>
                <br />
                <a href={`tel:${firmData.secondaryPhoneClean}`} class="text-[var(--color-text-secondary)]">{firmData.secondaryPhone}</a>
              </div>

              <div>
                <p class="text-[var(--color-text-tertiary)] text-xs font-medium uppercase tracking-wider mb-1">Email</p>
                <a href={`mailto:${firmData.email}`} class="text-[var(--color-text-secondary)]">{firmData.email}</a>
              </div>

              <div>
                <p class="text-[var(--color-text-tertiary)] text-xs font-medium uppercase tracking-wider mb-1">Address</p>
                <p class="text-[var(--color-text-secondary)]">{firmData.address.full}</p>
                <a
                  href={`https://maps.google.com/?q=${encodeURIComponent(firmData.address.full)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 mt-2 text-xs font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
                                 >
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Get directions
                </a>
              </div>

              <div>
                <p class="text-[var(--color-text-tertiary)] text-xs font-medium uppercase tracking-wider mb-1">Hours</p>
                <p class="text-[var(--color-text-secondary)]">{firmData.hours}</p>
                <p class="text-[var(--color-text-tertiary)] text-xs mt-1">Evening & weekend by arrangement</p>
              </div>
            </div>
          </div>

          <div class="mt-5 rounded-xl border border-[var(--color-border)] border-l-4 border-l-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-7">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <div>
                <h4 class="font-semibold text-sm mb-2" style="font-family: var(--font-heading);">Urgent matter?</h4>
                <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">
                  For time-sensitive matters (e.g., 21-day unfair dismissal deadline), call directly and mention urgency. We'll prioritise your consultation.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
