---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
import { firmData } from "../data/firm";
---

<BaseLayout
  title="Privacy Policy | WorkRight Legal"
  description="WorkRight Legal's privacy policy. How we collect, use, and protect your personal information in accordance with Australian Privacy Principles."
  noindex={true}
>
  <BreadcrumbSchema
    items={[
      { name: "Home", url: firmData.url },
      { name: "Privacy Policy", url: `${firmData.url}/privacy-policy` },
    ]}
  />

  <Hero
    heading="Privacy policy"
    subheading="How we collect, use, and protect your personal information."
    variant="page"
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 lg:px-10">
      <div class="prose prose-sm max-w-none space-y-10 text-[var(--color-text-secondary)]">

        <div class="reveal">
          <p class="text-xs uppercase tracking-[0.15em] text-[var(--color-text-tertiary)] font-medium mb-6">
            Last updated: 1 January 2025
          </p>

          <p class="leading-relaxed">
            WorkRight Legal ("we", "our", "us") is committed to protecting the privacy of our clients and website visitors. This Privacy Policy explains how we collect, use, disclose, and safeguard your personal information in accordance with the <em>Privacy Act 1988</em> (Cth) and the Australian Privacy Principles (APPs).
          </p>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">1. Information we collect</h2>
          <p class="mt-3 leading-relaxed">We may collect the following types of personal information:</p>
          <ul class="mt-3 space-y-2 list-disc pl-5">
            <li>Name, email address, phone number, and postal address</li>
            <li>Employment details relevant to your legal matter</li>
            <li>Information provided through our contact form or during consultations</li>
            <li>Website usage data collected via cookies and analytics tools</li>
          </ul>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">2. How we collect information</h2>
          <p class="mt-3 leading-relaxed">We collect personal information:</p>
          <ul class="mt-3 space-y-2 list-disc pl-5">
            <li>Directly from you when you contact us, submit a form, or engage our services</li>
            <li>From third parties such as courts, tribunals, or other legal practitioners with your consent</li>
            <li>Automatically through cookies and similar technologies when you visit our website</li>
          </ul>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">3. How we use your information</h2>
          <p class="mt-3 leading-relaxed">We use your personal information to:</p>
          <ul class="mt-3 space-y-2 list-disc pl-5">
            <li>Provide legal advice and representation</li>
            <li>Communicate with you about your matter</li>
            <li>Respond to enquiries submitted through our website</li>
            <li>Comply with legal and regulatory obligations</li>
            <li>Improve our website and services</li>
          </ul>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">4. Disclosure of information</h2>
          <p class="mt-3 leading-relaxed">
            We will not sell or rent your personal information to third parties. We may disclose your information to:
          </p>
          <ul class="mt-3 space-y-2 list-disc pl-5">
            <li>Courts, tribunals, and regulatory bodies as required in the course of your matter</li>
            <li>Other legal practitioners, barristers, or expert witnesses engaged on your behalf</li>
            <li>Service providers who assist us with IT, hosting, or administrative functions</li>
          </ul>
          <p class="mt-3 leading-relaxed">
            All disclosures are made in accordance with our professional obligations and applicable privacy laws.
          </p>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">5. Legal professional privilege</h2>
          <p class="mt-3 leading-relaxed">
            Communications between you and WorkRight Legal are protected by legal professional privilege. We will not disclose privileged information without your express consent, except as required by law.
          </p>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">6. Data security</h2>
          <p class="mt-3 leading-relaxed">
            We take reasonable steps to protect your personal information from misuse, interference, loss, unauthorised access, modification, or disclosure. Our security measures include encrypted communications, secure file storage, and restricted access to client files.
          </p>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">7. Cookies and analytics</h2>
          <p class="mt-3 leading-relaxed">
            Our website uses cookies and similar technologies to enhance your browsing experience and collect anonymous usage data. You can control cookie settings through your browser preferences. We do not use cookies to collect personally identifiable information without your consent.
          </p>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">8. Your rights</h2>
          <p class="mt-3 leading-relaxed">Under the Australian Privacy Principles, you have the right to:</p>
          <ul class="mt-3 space-y-2 list-disc pl-5">
            <li>Request access to the personal information we hold about you</li>
            <li>Request correction of any inaccurate or outdated information</li>
            <li>Make a complaint about how we handle your personal information</li>
          </ul>
          <p class="mt-3 leading-relaxed">
            To exercise these rights, contact us using the details below.
          </p>
        </div>

        <div class="reveal">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">9. Changes to this policy</h2>
          <p class="mt-3 leading-relaxed">
            We may update this Privacy Policy from time to time. Any changes will be posted on this page with an updated effective date. We encourage you to review this policy periodically.
          </p>
        </div>

        <div class="reveal border-t border-[var(--color-border)] pt-8">
          <h2 class="text-xl font-semibold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-heading);">10. Contact us</h2>
          <p class="mt-3 leading-relaxed">
            If you have questions about this Privacy Policy or wish to make a privacy-related complaint, please contact us:
          </p>
          <div class="mt-4 text-sm space-y-1">
            <p><strong class="text-[var(--color-text)]">WorkRight Legal</strong></p>
            <p>{firmData.address.full}</p>
            <p>Phone: <a href={`tel:${firmData.phoneClean}`} class="underline">{firmData.phone}</a></p>
            <p>Email: <a href={`mailto:${firmData.email}`} class="underline">{firmData.email}</a></p>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
