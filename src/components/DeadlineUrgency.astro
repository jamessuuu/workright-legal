---
/**
 * DeadlineUrgency — 21-day Fair Work Commission deadline awareness.
 * Empathetic, not panic-inducing. Channels urgency into productive action.
 */
---

<section class="py-6 lg:py-8 reveal">
  <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
    <div class="deadline-card rounded-xl p-6 lg:p-7 max-w-4xl mx-auto">
      <div class="flex items-start gap-4">
        <!-- Clock icon -->
        <div class="shrink-0 w-10 h-10 rounded-full bg-[var(--color-accent-subtle)] flex items-center justify-center">
          <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
        </div>
        <div>
          <h2
            class="text-xl lg:text-2xl font-bold tracking-tight"
            style="font-family: var(--font-heading);"
          >
            Fired in the last 21 days? You still have time.
          </h2>
          <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
            The Fair Work Commission has a 21-day deadline for dismissal claims. The sooner you reach out, the stronger your position.
          </p>
          <div class="mt-4">
            <a href="/check-my-case" class="btn btn-primary text-xs py-3 px-5">
              Check if you're still in time
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
