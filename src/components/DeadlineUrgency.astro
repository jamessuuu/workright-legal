---
interface Props {
  days?: number;
  message?: string;
}

const {
  days = 21,
  message = "days to lodge an unfair dismissal claim with the Fair Work Commission",
} = Astro.props;
---

<div class="bg-[var(--color-accent)] text-white reveal" role="alert">
  <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-3">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-6">
      <div class="flex items-center gap-3">
        <span class="text-[2rem] font-bold leading-none tracking-tight" style="font-family: var(--font-heading);">
          {days}
        </span>
        <span class="text-sm font-medium leading-snug">
          {message}
        </span>
      </div>
      <a
        href="/check-my-case"
        class="sm:ml-auto text-sm font-semibold underline underline-offset-2 decoration-white/60 hover:decoration-white transition-colors whitespace-nowrap shrink-0"
      >
        Check your deadline &rarr;
      </a>
    </div>
  </div>
</div>
