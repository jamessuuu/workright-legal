---
import { firmData } from "../data/firm";

interface Props {
  heading: string;
  subheading?: string;
  variant?: "default" | "dark" | "warm";
}

const { heading, subheading, variant = "dark" } = Astro.props;
const isDark = variant === "dark";
const isWarm = variant === "warm";
---

<section
  class:list={[
    "relative overflow-hidden reveal",
    isDark ? "section-dark gradient-mesh-dark py-24 lg:py-32" :
    isWarm ? "section-warm py-20 lg:py-28" :
    "bg-[var(--color-accent-subtle)] py-20 lg:py-28 border-t border-[var(--color-border)]",
  ]}
>
  <!-- Decorative elements for dark variant -->
  {isDark && (
    <div class="absolute top-0 right-[15%] w-96 h-96 rounded-full bg-[var(--color-accent)] opacity-[0.04] blur-3xl floating-slow" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-[10%] w-64 h-64 rounded-full bg-[var(--color-accent-light)] opacity-[0.03] blur-2xl floating" aria-hidden="true"></div>
  )}

  <div class="relative z-10 max-w-4xl mx-auto px-5 sm:px-8 lg:px-12 text-center">
    <h2
      class:list={[
        "text-3xl lg:text-[3rem] font-bold tracking-tight leading-[1.08]",
        isDark && "text-[var(--color-text-on-dark)]",
      ]}
      style="font-family: var(--font-heading);"
    >
      {heading}
    </h2>
    {subheading && (
      <p
        class:list={[
          "mt-6 text-lg lg:text-xl leading-relaxed max-w-2xl mx-auto",
          isDark ? "text-[var(--color-text-on-dark-secondary)]" : "text-[var(--color-text-secondary)]",
        ]}
      >
        {subheading}
      </p>
    )}
    <div class="mt-10 flex flex-wrap items-center justify-center gap-5">
      <a href="/contact" class:list={["btn text-base", isDark ? "btn-primary-dark" : "btn-primary"]}>
        Book Free Consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={`tel:${firmData.secondaryPhoneClean}`}
        class:list={["btn text-base", isDark ? "btn-outline-dark" : "btn-outline"]}
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {firmData.secondaryPhone}
      </a>
    </div>
    <p
      class:list={[
        "mt-6 text-sm",
        isDark ? "text-[var(--color-text-on-dark-secondary)]" : "text-[var(--color-text-tertiary)]",
      ]}
    >
      Free 30-minute consultation &middot; Response within 24 hours
    </p>
  </div>
</section>
