---
import { firmData } from "../data/firm";

interface Props {
  heading?: string;
  subheading?: string;
  variant?: "default" | "dark" | "warm";
  emotion?: "home" | "unfair-dismissal" | "discrimination" | "bullying" | "contracts" | "redundancy" | "general-protections";
}

const emotionCopy: Record<string, { heading: string; subheading: string }> = {
  "home": {
    heading: "You don't have to figure this out alone",
    subheading: "Fired yesterday? Been dealing with this for months? Either way, we'll listen. Free call, no strings attached.",
  },
  "unfair-dismissal": {
    heading: "Think you were fired unfairly? Let's talk.",
    subheading: "You have 21 days to act. A free call with us will tell you exactly where you stand.",
  },
  "discrimination": {
    heading: "What happened to you was not okay",
    subheading: "Discrimination at work is unlawful. You deserve better, and we can help you do something about it.",
  },
  "bullying": {
    heading: "You deserve to feel safe at work",
    subheading: "Nobody should dread Monday mornings. Let's put a stop to it together.",
  },
  "contracts": {
    heading: "Don't sign anything until you talk to us",
    subheading: "That contract was written to protect your employer, not you. Let us read the fine print.",
  },
  "redundancy": {
    heading: "Something feel off about your redundancy?",
    subheading: "Not every redundancy is genuine. Not every payout is fair. We'll tell you the truth.",
  },
  "general-protections": {
    heading: "Punished for standing up for yourself?",
    subheading: "If your employer retaliated because you exercised a workplace right, you may be entitled to uncapped compensation.",
  },
};

const { heading: headingProp, subheading: subheadingProp, variant = "dark", emotion } = Astro.props;
const resolved = emotion ? emotionCopy[emotion] : null;
const heading = resolved?.heading || headingProp || "Ready to discuss your case?";
const subheading = resolved?.subheading || subheadingProp;
const isDark = variant === "dark";
const isWarm = variant === "warm";
---

<section
  class:list={[
    "relative overflow-hidden reveal",
    isDark ? "section-dark gradient-mesh-dark py-16 lg:py-20" :
    isWarm ? "section-warm py-16 lg:py-20" :
    "bg-[var(--color-accent-subtle)] py-16 lg:py-20 border-t border-[var(--color-border)]",
  ]}
>
  <!-- Decorative elements for dark variant -->
  {isDark && (
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-[2px] accent-line opacity-30" aria-hidden="true"></div>
  )}

  <div class="relative z-10 max-w-4xl mx-auto px-5 sm:px-8 lg:px-12 text-center">
    <h2
      class:list={[
        "text-2xl lg:text-[2.5rem] font-bold tracking-tight leading-[1.08]",
        isDark && "text-[var(--color-text-on-dark)]",
      ]}
      style="font-family: var(--font-heading);"
    >
      {heading}
    </h2>
    {subheading && (
      <p
        class:list={[
          "mt-4 text-base lg:text-lg leading-relaxed max-w-2xl mx-auto",
          isDark ? "text-[var(--color-text-on-dark-secondary)]" : "text-[var(--color-text-secondary)]",
        ]}
      >
        {subheading}
      </p>
    )}
    <div class="mt-7 flex flex-wrap items-center justify-center gap-4">
      <a href="/contact" class:list={["btn text-sm", isDark ? "btn-primary-dark" : "btn-primary"]}>
        Book Free Consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={`tel:${firmData.secondaryPhoneClean}`}
        class:list={["btn text-sm", isDark ? "btn-outline-dark" : "btn-outline"]}
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {firmData.secondaryPhone}
      </a>
    </div>
    <p
      class:list={[
        "mt-6 text-sm",
        isDark ? "text-[var(--color-text-on-dark-secondary)]" : "text-[var(--color-text-tertiary)]",
      ]}
    >
      Free 30-minute consultation &middot; Response within 24 hours
    </p>
  </div>
</section>
