---
import { firmData, practiceAreasList } from "../data/firm";
const year = new Date().getFullYear();
---

<footer class="section-dark mt-auto">
  <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-10">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-baseline gap-0.5 group">
          <span class="text-xl font-semibold tracking-tight text-[var(--color-text-on-dark)] group-hover:text-[var(--color-accent-light)] transition-colors" style="font-family: var(--font-heading);">
            WorkRight
          </span>
          <span class="text-[var(--color-accent-light)] font-medium text-sm ml-1">Legal</span>
        </a>
        <p class="text-sm text-[var(--color-text-on-dark-secondary)] leading-relaxed mt-4 max-w-xs">
          Specialist employment lawyers dedicated exclusively to protecting employee rights across Greater Sydney.
        </p>
        {(firmData.social.linkedin || firmData.social.facebook) && (
          <div class="mt-6 flex items-center gap-4">
            {firmData.social.linkedin && (
              <a href={firmData.social.linkedin} aria-label="LinkedIn" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-[var(--color-text-on-dark-secondary)] hover:bg-[var(--color-accent)] hover:text-white transition-all duration-300" rel="noopener noreferrer" target="_blank">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
            {firmData.social.facebook && (
              <a href={firmData.social.facebook} aria-label="Facebook" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-[var(--color-text-on-dark-secondary)] hover:bg-[var(--color-accent)] hover:text-white transition-all duration-300" rel="noopener noreferrer" target="_blank">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Practice Areas -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-accent-light)] mb-5"
          style="font-family: var(--font-body);"
        >
          Services
        </h3>
        <ul class="space-y-3">
          {practiceAreasList.map((area) => (
            <li>
              <a href={`/services/${area.slug}`} class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors duration-200">
                {area.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-accent-light)] mb-5"
          style="font-family: var(--font-body);"
        >
          Contact
        </h3>
        <div class="space-y-3 text-sm text-[var(--color-text-on-dark-secondary)]">
          <p>{firmData.address.full}</p>
          <p>
            <a href={`tel:${firmData.phoneClean}`} class="hover:text-[var(--color-accent-light)] transition-colors">
              {firmData.phone}
            </a>
          </p>
          <p>
            <a href={`mailto:${firmData.email}`} class="hover:text-[var(--color-accent-light)] transition-colors">
              {firmData.email}
            </a>
          </p>
          <p class="text-white/50">{firmData.hours}</p>
        </div>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-accent-light)] mb-5"
          style="font-family: var(--font-body);"
        >
          Company
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/about" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">About</a>
          </li>
          <li>
            <a href="/team" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">Team</a>
          </li>
          <li>
            <a href="/testimonials" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">Testimonials</a>
          </li>
          <li>
            <a href="/news" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">News</a>
          </li>
          <li>
            <a href="/faq" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">FAQ</a>
          </li>
          <li>
            <a href="/contact" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">Contact</a>
          </li>
          <li>
            <a href="/privacy-policy" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">Privacy Policy</a>
          </li>
          <li>
            <a href="/terms-of-service" class="text-sm text-[var(--color-text-on-dark-secondary)] hover:text-[var(--color-accent-light)] transition-colors">Terms of Service</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Disclaimer + Copyright -->
    <div class="mt-16 pt-8 border-t border-white/10">
      <p class="text-xs text-white/50 leading-relaxed max-w-3xl">
        The information on this website is for general information purposes only.
        Nothing on this site should be taken as legal advice for any individual case or situation.
        This information is not intended to create, and receipt or viewing does not constitute,
        a solicitor-client relationship.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <p class="text-xs text-white/50">
          &copy; {year} {firmData.name}. All rights reserved.
        </p>
        <p class="text-xs text-white/50">
          ABN 12 345 678 901
        </p>
      </div>
    </div>
  </div>
</footer>
