---
import { firmData } from "../data/firm";
import HeroTextReveal from "./HeroTextReveal";
import SiteButton from "./SiteButton.astro";

interface Props {
  heading: string;
  subheading?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  showStats?: boolean;
  stats?: { value: string; label: string }[];
  variant?: "home" | "practice" | "page";
}

const {
  heading,
  subheading,
  ctaText = "Free Consultation",
  ctaLink = "/contact",
  secondaryCtaText,
  secondaryCtaLink,
  showStats = false,
  stats = [],
  variant = "page",
} = Astro.props;

const isHome = variant === "home";
const isPractice = variant === "practice";
---

{isHome ? (
  <!-- HOME HERO — Full-width dark dramatic with ambient video -->
  <section class="relative overflow-hidden section-dark gradient-mesh-dark">
    <!-- Ambient video background -->
    <video
      class="absolute inset-0 w-full h-full object-cover hero-video"
      id="hero-bg-video"
      aria-label="Ambient office background video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    >
      <source src="/videos/hero-office-loop.mp4" type="video/mp4" />
    </video>
    <!-- Video overlay — dark on left for text readability, lighter on right to show video -->
    <div class="absolute inset-0" aria-hidden="true" style="background: linear-gradient(to right, var(--color-surface-dark) 0%, rgba(28,24,21,0.85) 35%, rgba(28,24,21,0.5) 65%, rgba(28,24,21,0.3) 100%);"></div>
    <!-- Top/bottom edge darkening -->
    <div class="absolute inset-0" aria-hidden="true" style="background: linear-gradient(to bottom, var(--color-surface-dark) 0%, transparent 15%, transparent 85%, rgba(28,24,21,0.8) 100%);"></div>

    <div class="relative z-10 max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 pt-14 pb-16 lg:pt-20 lg:pb-24">
      <div class="max-w-5xl">
        <!-- Overline badge -->
        <div class="hero-reveal hero-reveal-1 flex items-center gap-4 mb-6">
          <div class="h-[1.5px] w-10 accent-line"></div>
          <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent-light)]">
            Sydney Employment Lawyers
          </span>
        </div>

        <HeroTextReveal
          client:visible
          segments={[
            { text: "Protecting", className: "text-[var(--color-text-on-dark)]" },
            { text: "employee rights", className: "text-gradient" },
            { text: "across Greater Sydney", className: "text-[var(--color-text-on-dark)]", breakAfter: false },
          ]}
          subheading="Fired unfairly? Bullied at work? Something feel wrong? We hear you."
        />

        {subheading && (
          <p class="hero-reveal hero-reveal-3 mt-3 text-base lg:text-lg text-[var(--color-text-on-dark-secondary)] leading-relaxed max-w-2xl">
            {subheading}
          </p>
        )}

        <div class="hero-reveal hero-reveal-4 mt-7 flex flex-wrap items-center gap-4">
          <SiteButton href={ctaLink} variant="primaryDark" size="sm">
            {ctaText}
            <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </SiteButton>
          {secondaryCtaText && secondaryCtaLink && (
            <SiteButton href={secondaryCtaLink} variant="outlineDark" size="sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {secondaryCtaText}
            </SiteButton>
          )}
        </div>

        <!-- Trust indicators -->
        <div class="hero-badge mt-8 flex flex-wrap items-center gap-5 text-sm text-[var(--color-text-on-dark-secondary)]">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--color-accent-light)]" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            Free consultation
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--color-accent-light)]" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            No win, no fee
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--color-accent-light)]" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            15+ years experience
          </span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator — gentle bouncing chevron -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2" aria-hidden="true">
      <span class="text-[10px] uppercase tracking-[0.2em] font-medium text-[var(--color-text-on-dark-secondary)] opacity-60">Scroll</span>
      <svg class="w-5 h-5 text-[var(--color-accent-light)] animate-bounce-gentle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>

    <!-- Bottom accent line -->
    <div class="absolute bottom-0 left-0 right-0 h-[2px] accent-line hero-line"></div>

    <script>
      const vid = document.getElementById("hero-bg-video") as HTMLVideoElement | null;
      if (vid) {
        const show = () => vid.classList.add("is-playing");
        if (vid.readyState >= 2) show();
        else vid.addEventListener("playing", show, { once: true });
      }
    </script>
  </section>
) : (
  <!-- PRACTICE / PAGE HERO — Light variant -->
  <section
    class:list={[
      "relative overflow-hidden gradient-mesh",
      isPractice ? "pt-16 pb-20 lg:pt-24 lg:pb-28" : "pt-14 pb-16 lg:pt-20 lg:pb-24",
    ]}
  >
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class:list={[isPractice ? "max-w-4xl" : "max-w-3xl"]}>
        {isPractice && (
          <div class="hero-reveal hero-reveal-1 flex items-center gap-3 mb-6">
            <div class="h-[1.5px] w-10 accent-line"></div>
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">
              Employment Law
            </span>
          </div>
        )}

        <h1
          class:list={[
            "font-bold tracking-tight hero-reveal hero-reveal-2",
            isPractice
              ? "text-[clamp(2.25rem,5vw,4rem)] leading-[1.15]"
              : "text-[clamp(2rem,4vw,3.25rem)] leading-[1.08]",
          ]}
          style="font-family: var(--font-heading);"
        >
          {heading}
        </h1>

        {subheading && (
          <p
            class:list={[
              "hero-reveal hero-reveal-3 text-[var(--color-text-secondary)] leading-relaxed",
              isPractice ? "mt-6 text-lg lg:text-xl max-w-2xl" : "mt-5 text-base lg:text-lg",
            ]}
          >
            {subheading}
          </p>
        )}

        <div class="hero-reveal hero-reveal-4 mt-8 flex flex-wrap items-center gap-4">
          <SiteButton href={ctaLink}>
            {ctaText}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </SiteButton>
          {secondaryCtaText && secondaryCtaLink && (
            <SiteButton href={secondaryCtaLink} variant="outline">
              {secondaryCtaText}
            </SiteButton>
          )}
        </div>
      </div>

      <!-- Stats -->
      {showStats && stats.length > 0 && (
        <div class="mt-20 pt-10 border-t border-[var(--color-border)]">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 stagger-children">
            {stats.map((stat) => (
              <div>
                <div class="text-3xl lg:text-4xl font-bold tracking-tight text-gradient" style="font-family: var(--font-heading);">
                  {stat.value}
                </div>
                <div class="mt-1 text-sm text-[var(--color-text-tertiary)] font-medium">
                  {stat.label}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
)}
