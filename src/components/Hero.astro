---
import { firmData } from "../data/firm";

interface Props {
  heading: string;
  subheading?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  showStats?: boolean;
  stats?: { value: string; label: string }[];
  variant?: "home" | "practice" | "page";
}

const {
  heading,
  subheading,
  ctaText = "Free Consultation",
  ctaLink = "/contact",
  secondaryCtaText,
  secondaryCtaLink,
  showStats = false,
  stats = [],
  variant = "page",
} = Astro.props;

const isHome = variant === "home";
const isPractice = variant === "practice";
---

<section
  class:list={[
    "relative overflow-hidden",
    isHome ? "pt-20 pb-24 lg:pt-32 lg:pb-36" : isPractice ? "pt-14 pb-16 lg:pt-20 lg:pb-24" : "pt-12 pb-14 lg:pt-16 lg:pb-20",
  ]}
>
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-10">
    <div class:list={[isHome ? "max-w-4xl" : "max-w-3xl"]}>
      <!-- Overline -->
      {isHome && (
        <div class="hero-reveal hero-reveal-1 flex items-center gap-3 mb-8">
          <div class="h-px w-8 bg-[var(--color-accent)]"></div>
          <span class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-accent)]">
            Sydney Employment Lawyers
          </span>
        </div>
      )}

      <h1
        class:list={[
          "font-bold tracking-tight hero-reveal hero-reveal-2",
          isHome
            ? "text-[clamp(2.5rem,6vw,5rem)] leading-[1.05]"
            : isPractice
              ? "text-[clamp(2rem,4.5vw,3.5rem)] leading-[1.1]"
              : "text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.15]",
        ]}
        style="font-family: var(--font-heading);"
      >
        {heading}
      </h1>

      {subheading && (
        <p
          class:list={[
            "hero-reveal hero-reveal-3 text-[var(--color-text-secondary)] leading-relaxed",
            isHome ? "mt-7 text-lg lg:text-xl max-w-2xl" : "mt-5 text-base lg:text-lg",
          ]}
        >
          {subheading}
        </p>
      )}

      <div class="hero-reveal hero-reveal-4 mt-8 flex flex-wrap items-center gap-4">
        <a href={ctaLink} class="btn btn-primary">
          {ctaText}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        {secondaryCtaText && secondaryCtaLink && (
          <a href={secondaryCtaLink} class="btn btn-outline">
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>

    <!-- Stats -->
    {showStats && stats.length > 0 && (
      <div class="mt-20 pt-10 border-t border-[var(--color-border)]">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 stagger-children">
          {stats.map((stat) => (
            <div>
              <div class="text-3xl lg:text-4xl font-bold tracking-tight" style="font-family: var(--font-heading);">
                {stat.value}
              </div>
              <div class="mt-1 text-sm text-[var(--color-text-tertiary)] font-medium">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- Decorative line -->
  {isHome && (
    <div class="absolute bottom-0 left-0 right-0 h-px bg-[var(--color-border)] hero-line"></div>
  )}
</section>
