---
import { firmData } from "../../data/firm";

interface Props {
  name: string;
  description: string;
  url: string;
  serviceAreas?: string[];
}

const { name, description, url, serviceAreas } = Astro.props;

const areaServed = serviceAreas && serviceAreas.length > 0
  ? serviceAreas.map((area) => ({
      "@type": "City" as const,
      name: area,
      containedInPlace: { "@type": "State" as const, name: "New South Wales" },
    }))
  : {
      "@type": "City" as const,
      name: "Sydney",
      containedInPlace: { "@type": "State" as const, name: "New South Wales" },
    };

const schema = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  name,
  description,
  url,
  provider: {
    "@type": "Organization",
    name: firmData.name,
    url: firmData.url,
  },
  areaServed,
  offers: {
    "@type": "Offer",
    name: "Free Initial Consultation",
    price: "0",
    priceCurrency: "AUD",
    description: "Free 30-minute consultation to discuss your case",
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
