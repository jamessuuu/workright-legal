---
import { firmData } from "../../data/firm";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: firmData.name,
  url: firmData.url,
  description: firmData.tagline,
  publisher: {
    "@type": "Organization",
    name: firmData.name,
    url: firmData.url,
  },
  inLanguage: "en-AU",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${firmData.url}/faq?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
  audience: {
    "@type": "Audience",
    audienceType: "Employees seeking employment law advice in Australia",
    geographicArea: {
      "@type": "AdministrativeArea",
      name: "New South Wales, Australia",
    },
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
