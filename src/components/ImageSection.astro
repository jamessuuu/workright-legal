---
interface Props {
  src: string;
  alt: string;
  aspectRatio?: "video" | "wide" | "square" | "portrait";
  rounded?: boolean;
  caption?: string;
}

const {
  src,
  alt,
  aspectRatio = "video",
  rounded = true,
  caption,
} = Astro.props;

const aspectMap = {
  video: "aspect-video",
  wide: "aspect-[21/9]",
  square: "aspect-square",
  portrait: "aspect-[3/4]",
};
---

<figure class="reveal">
  <div class:list={[
    "overflow-hidden bg-[var(--color-surface-muted)]",
    aspectMap[aspectRatio],
    rounded ? "rounded-xl" : "",
  ]}>
    <img
      src={src}
      alt={alt}
      class="w-full h-full object-cover transition-transform duration-700 hover:scale-[1.02]"
      loading="lazy"
      decoding="async"
    />
  </div>
  {caption && (
    <figcaption class="mt-3 text-xs text-[var(--color-text-tertiary)]">
      {caption}
    </figcaption>
  )}
</figure>
