---
/**
 * ClientJourney — SVG path map with scroll-driven animation.
 * Desktop: winding SVG trail on the left, content cards on the right.
 * As the user scrolls, the path draws and stops light up.
 * Mobile: stacked timeline (no SVG path).
 */

const stages = [
  {
    label: "The moment it hits you",
    text: "The call ends. Your role is gone. Twenty-one days to act — and the clock is already ticking.",
    accent: "var(--color-accent)",
    number: "01",
  },
  {
    label: "You find us",
    text: "Hundreds face this every week. Most don't know their rights. You searched, you found us — that changes everything.",
    accent: "var(--color-accent-light)",
    number: "02",
  },
  {
    label: "Sarah listens",
    text: "Not just the facts — what this means for your family, your future. She's handled hundreds of these. She knows exactly what to do.",
    accent: "var(--color-accent)",
    number: "03",
  },
  {
    label: "We build your case",
    text: "While you're at home with your family, we're gathering evidence, negotiating, and preparing your Fair Work application.",
    accent: "var(--color-accent-light)",
    number: "04",
  },
  {
    label: "You move forward",
    text: "A fair settlement. Acknowledgment. You can breathe again, plan again. Your story didn't end with their decision.",
    accent: "var(--color-accent)",
    number: "05",
  },
];

// SVG path stop Y positions — measured to align with card centers in 5-row equal grid
// viewBox 0-800 maps to actual rendered height; positions derived from card center %
const stopPositions = [
  { cx: 100, cy: 71 },
  { cx: 50, cy: 236 },
  { cx: 150, cy: 400 },
  { cx: 50, cy: 565 },
  { cx: 100, cy: 729 },
];

const pathD = "M100,71 C100,130 50,165 50,236 C50,305 150,335 150,400 C150,468 50,498 50,565 C50,635 100,660 100,729";
---

<!-- Mobile: stacked timeline | Desktop: SVG path map -->
<section class="overflow-hidden" id="client-journey">
  <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-14 lg:py-20">
    <div class="max-w-2xl mb-12 reveal">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1.5px] w-8 accent-line"></div>
        <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)]">Your Journey</span>
      </div>
      <h2
        class="text-2xl lg:text-[2.25rem] font-bold tracking-tight leading-[1.08]"
        style="font-family: var(--font-heading);"
      >
        Here's what happens when you call us
      </h2>
      <p class="mt-3 text-base text-[var(--color-text-secondary)] leading-relaxed">
        From first call to fair outcome — this is what it looks like when someone fights for you.
      </p>
    </div>
  </div>

  <!-- Desktop: SVG path map + content cards -->
  <div class="hidden lg:block" id="journey-map">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 pb-10">
      <div class="grid grid-cols-[160px_1fr] gap-12 xl:gap-16">
        <!-- Left: SVG winding path -->
        <div class="relative" aria-hidden="true">
          <svg class="journey-map-svg w-full h-full" viewBox="0 0 200 800" preserveAspectRatio="none" style="overflow: visible;">
            <!-- Background path (dotted gray) -->
            <path
              class="journey-path-bg"
              d={pathD}
              stroke="var(--color-border)"
              stroke-width="2"
              fill="none"
              stroke-dasharray="4 8"
            />
            <!-- Animated path (accent, drawn by scroll) -->
            <path
              class="journey-path-active"
              d={pathD}
              stroke="var(--color-accent)"
              stroke-width="2.5"
              fill="none"
              stroke-linecap="round"
            />
            <!-- Stop circles -->
            {stopPositions.map((pos, i) => (
              <g class="journey-stop" data-index={i}>
                <!-- Outer glow ring -->
                <circle
                  cx={pos.cx}
                  cy={pos.cy}
                  r="16"
                  fill="var(--color-accent)"
                  opacity="0"
                  class="journey-stop-glow"
                />
                <!-- Stop circle -->
                <circle
                  cx={pos.cx}
                  cy={pos.cy}
                  r="8"
                  fill="var(--color-surface)"
                  stroke="var(--color-border)"
                  stroke-width="2"
                  class="journey-stop-circle"
                />
                <!-- Step number -->
                <text
                  x={pos.cx}
                  y={pos.cy + 1}
                  text-anchor="middle"
                  dominant-baseline="central"
                  class="journey-stop-number"
                  fill="var(--color-text-tertiary)"
                  font-size="9"
                  font-weight="700"
                  font-family="var(--font-body)"
                >
                  {i + 1}
                </text>
              </g>
            ))}
          </svg>
        </div>

        <!-- Right: Content cards (grid with equal rows to align with SVG stops) -->
        <div class="grid grid-rows-5 gap-4">
          {stages.map((stage, i) => (
            <div
              class="journey-map-card rounded-xl border border-[var(--color-border)] p-5 lg:p-6 transition-all duration-500 flex items-center"
              data-index={i}
              style={i === 0 ? "opacity: 1;" : "opacity: 0.3;"}
            >
              <div class="flex items-start gap-4">
                <span
                  class="journey-card-number inline-block text-3xl font-bold opacity-25 shrink-0 leading-none"
                  style={`color: ${stage.accent}; font-family: var(--font-heading);`}
                >
                  {stage.number}
                </span>
                <div>
                  <h3
                    class="text-lg lg:text-xl font-bold tracking-tight leading-tight"
                    style="font-family: var(--font-heading);"
                  >
                    {stage.label}
                  </h3>
                  <p class="mt-1.5 text-sm text-[var(--color-text-secondary)] leading-relaxed">
                    {stage.text}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile: Stacked cards (no SVG path) -->
  <div class="lg:hidden">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8">
      <div class="relative">
        <!-- Mobile timeline line -->
        <div class="journey-line lg:hidden" aria-hidden="true"></div>

        <div class="space-y-8">
          {stages.map((stage, i) => (
            <div class="journey-stage relative">
              <div class="relative pl-14">
                <!-- Mobile timeline dot -->
                <div class="absolute left-3 top-1 w-6 h-6 rounded-full border-2 border-[var(--color-accent)] bg-white flex items-center justify-center" aria-hidden="true">
                  <div class="w-2 h-2 rounded-full bg-[var(--color-accent)]"></div>
                </div>

                <span
                  class="inline-block text-xs font-semibold uppercase tracking-[0.2em] mb-2"
                  style={`color: ${stage.accent};`}
                >
                  Step {stage.number}
                </span>
                <h3
                  class="text-lg font-bold tracking-tight leading-tight"
                  style="font-family: var(--font-heading);"
                >
                  {stage.label}
                </h3>
                <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-relaxed">
                  {stage.text}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Closing CTA -->
  <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-14 lg:py-20">
    <div class="text-center reveal">
      <p class="text-base text-[var(--color-text-secondary)] mb-5">
        Your story doesn't have to end with your employer's decision.
      </p>
      <a href="/check-my-case" class="btn btn-primary">
        Start your journey
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
