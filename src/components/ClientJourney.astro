---
/**
 * ClientJourney — Immersive pinned scroll storytelling section.
 * Each stage pins and cross-fades as the user scrolls, creating
 * a narrative journey from crisis to resolution.
 * Uses GSAP ScrollTrigger pin + scrub.
 */

const stages = [
  {
    label: "The moment it hits you",
    text: "The call ends. Your role is gone. Twenty-one days to act — and the clock is already ticking.",
    accent: "var(--color-accent)",
    number: "01",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="24" cy="24" r="20"/><path d="M24 14v10l7 7"/></svg>`,
  },
  {
    label: "You find us",
    text: "Hundreds face this every week. Most don't know their rights. You searched, you found us — that changes everything.",
    accent: "var(--color-accent-light)",
    number: "02",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="20" cy="20" r="14"/><path d="M30 30l12 12"/><path d="M15 20h10M20 15v10"/></svg>`,
  },
  {
    label: "Sarah listens",
    text: "Not just the facts — what this means for your family, your future. She's handled hundreds of these. She knows exactly what to do.",
    accent: "var(--color-accent)",
    number: "03",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M8 24c0-8.8 7.2-16 16-16s16 7.2 16 16"/><path d="M8 24v4a4 4 0 004 4h2v-12h-2a4 4 0 00-4 4zM40 24v4a4 4 0 01-4 4h-2v-12h2a4 4 0 014 4z"/><path d="M36 32v2a4 4 0 01-4 4h-6"/></svg>`,
  },
  {
    label: "We build your case",
    text: "While you're at home with your family, we're gathering evidence, negotiating, and preparing your Fair Work application.",
    accent: "var(--color-accent-light)",
    number: "04",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="6" y="10" width="36" height="28" rx="3"/><path d="M6 18h36"/><path d="M14 26h8M14 32h12"/></svg>`,
  },
  {
    label: "You move forward",
    text: "A fair settlement. Acknowledgment. You can breathe again, plan again. Your story didn't end with their decision.",
    accent: "var(--color-accent)",
    number: "05",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M12 36l8-8 6 6 10-14"/><circle cx="24" cy="24" r="20"/></svg>`,
  },
];
---

<!-- Mobile: stacked cards | Desktop: pinned scroll -->
<section class="overflow-hidden" id="client-journey">
  <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-14 lg:py-20">
    <div class="max-w-2xl mb-12 reveal">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1.5px] w-8 accent-line"></div>
        <span class="text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-accent)]">Your Journey</span>
      </div>
      <h2
        class="text-2xl lg:text-[2.25rem] font-bold tracking-tight leading-[1.08]"
        style="font-family: var(--font-heading);"
      >
        Here's what happens when you call us
      </h2>
      <p class="mt-3 text-base text-[var(--color-text-secondary)] leading-relaxed">
        From first call to fair outcome — this is what it looks like when someone fights for you.
      </p>
    </div>
  </div>

  <!-- Desktop: Pinned scroll container -->
  <div class="hidden lg:block journey-pinned" id="journey-pinned">
    <div class="journey-pinned-inner relative" style="height: 100vh;">
      <!-- Progress bar -->
      <div class="absolute left-8 xl:left-16 top-1/2 -translate-y-1/2 h-48 w-[2px] bg-[var(--color-border)]" aria-hidden="true">
        <div class="journey-progress-bar w-full bg-[var(--color-accent)] origin-top" style="height: 0%;"></div>
      </div>

      <!-- Stage cards (stacked, cross-faded via GSAP) -->
      {stages.map((stage, i) => (
        <div
          class="journey-card absolute inset-0 flex items-center"
          data-index={i}
          style={i === 0 ? "" : "opacity: 0;"}
        >
          <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 w-full">
            <div class="grid grid-cols-2 gap-20 items-center">
              <!-- Text -->
              <div class:list={[i % 2 === 1 ? "order-2" : "order-1"]}>
                <span
                  class="inline-block text-6xl font-bold opacity-10 mb-2"
                  style={`color: ${stage.accent}; font-family: var(--font-heading);`}
                >
                  {stage.number}
                </span>
                <h3
                  class="journey-card-heading text-2xl lg:text-3xl font-bold tracking-tight leading-tight"
                  style="font-family: var(--font-heading);"
                >
                  {stage.label}
                </h3>
                <p class="journey-card-text mt-4 text-base text-[var(--color-text-secondary)] leading-relaxed max-w-lg">
                  {stage.text}
                </p>
              </div>

              <!-- Visual: Icon -->
              <div class:list={[
                "flex items-center justify-center",
                i % 2 === 1 ? "order-1" : "order-2",
              ]}>
                <div class="journey-card-icon relative w-32 h-32 text-[var(--color-accent)]" style={`color: ${stage.accent};`}>
                  <!-- Ambient glow ring -->
                  <div class="absolute inset-[-1rem] rounded-full opacity-10" style={`background: radial-gradient(circle, ${stage.accent} 0%, transparent 70%);`}></div>
                  <div set:html={stage.icon} />
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile: Stacked cards (no pin) -->
  <div class="lg:hidden">
    <div class="max-w-[90rem] mx-auto px-5 sm:px-8">
      <div class="relative">
        <!-- Mobile timeline line -->
        <div class="journey-line lg:hidden" aria-hidden="true"></div>

        <div class="space-y-8">
          {stages.map((stage, i) => (
            <div class="journey-stage relative">
              <div class="relative pl-14">
                <!-- Mobile timeline dot -->
                <div class="absolute left-3 top-1 w-6 h-6 rounded-full border-2 border-[var(--color-accent)] bg-white flex items-center justify-center" aria-hidden="true">
                  <div class="w-2 h-2 rounded-full bg-[var(--color-accent)]"></div>
                </div>

                <span
                  class="inline-block text-xs font-semibold uppercase tracking-[0.2em] mb-2"
                  style={`color: ${stage.accent};`}
                >
                  Step {stage.number}
                </span>
                <h3
                  class="text-lg font-bold tracking-tight leading-tight"
                  style="font-family: var(--font-heading);"
                >
                  {stage.label}
                </h3>
                <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-relaxed">
                  {stage.text}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Closing CTA -->
  <div class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-12 xl:px-16 py-14 lg:py-20">
    <div class="text-center reveal">
      <p class="text-base text-[var(--color-text-secondary)] mb-5">
        Your story doesn't have to end with your employer's decision.
      </p>
      <a href="/check-my-case" class="btn btn-primary">
        Start your journey
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
