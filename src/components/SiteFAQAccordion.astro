---
import {
  Accordion,
  AccordionItem,
  AccordionTrigger,
  AccordionContent,
} from "@/components/starwind/accordion";

interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<Accordion type="single" class="divide-y divide-[var(--color-border)]">
  {faqs.map((faq, index) => (
    <AccordionItem value={`faq-${index}`} class="border-b-0">
      <AccordionTrigger class="py-6 text-[var(--color-text)] text-base lg:text-lg font-medium hover:text-[var(--color-accent)]">
        <span class="pr-6 flex items-start gap-4 text-left">
          <span class="text-sm font-semibold text-[var(--color-accent)] opacity-60 tabular-nums shrink-0 mt-0.5">{String(index + 1).padStart(2, '0')}</span>
          <span>{faq.question}</span>
        </span>
        <svg
          slot="icon"
          class="w-5 h-5 shrink-0 text-[var(--color-accent)] transition-transform duration-200"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </AccordionTrigger>
      <AccordionContent>
        <p class="text-base lg:text-[1.0625rem] text-[var(--color-text-secondary)] leading-relaxed pr-10">{faq.answer}</p>
      </AccordionContent>
    </AccordionItem>
  ))}
</Accordion>
