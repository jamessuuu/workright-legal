---
interface Props {
  areas: string[];
}

const { areas } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {areas.map((area) => (
    <span class="text-sm font-medium text-[var(--color-text-secondary)] bg-[var(--color-surface-muted)] border border-[var(--color-border-subtle)] px-3 py-2 rounded-full">
      {area}
    </span>
  ))}
</div>
