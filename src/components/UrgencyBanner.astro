---
import { Alert, AlertDescription } from "@/components/starwind/alert";

interface Props {
  days: number;
  message: string;
  ctaText?: string;
  ctaLink?: string;
}

const { days, message, ctaText = "Get Free Case Assessment", ctaLink = "/contact" } = Astro.props;
---

<Alert variant="warning" class="bg-[var(--color-primary)] text-white border-none rounded-none py-4 px-5 sm:px-8 urgency-enter">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
    <div class="flex items-center gap-3 text-center sm:text-left">
      <span class="hidden sm:flex items-center justify-center w-10 h-10 rounded-full bg-white/10 text-lg font-bold shrink-0" style="font-family: var(--font-heading);">
        {days}
      </span>
      <AlertDescription class="text-sm sm:text-base font-medium leading-snug text-white">{message}</AlertDescription>
    </div>
    <a
      href={ctaLink}
      class="shrink-0 inline-flex items-center gap-2 px-5 py-2.5 bg-white text-[var(--color-primary)] text-sm font-medium rounded-full hover:bg-[var(--color-surface-muted)] transition-colors"
    >
      {ctaText}
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7" />
      </svg>
    </a>
  </div>
</Alert>
