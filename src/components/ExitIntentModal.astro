---
/**
 * ExitIntentModal - Shows when user moves cursor toward browser chrome
 * on pages with time-sensitive deadlines (unfair dismissal, general protections).
 * Non-intrusive, dismissible, shown only once per session.
 *
 * Uses Starwind Dialog with programmatic opening via dialog:open custom event.
 */
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogDescription,
  DialogFooter,
} from "@/components/starwind/dialog";
import SiteButton from "@/components/SiteButton.astro";

interface Props {
  days: number;
  practiceArea: string;
}

const { days, practiceArea } = Astro.props;
---

<Dialog id="exit-intent-dialog">
  <DialogContent class="bg-[var(--color-surface)] border-[var(--color-border)] max-w-lg rounded-xl">
    <DialogHeader class="text-left">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-[var(--color-accent-subtle)] flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
        </div>
        <p class="text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-text-tertiary)]">Time-sensitive</p>
      </div>

      <DialogTitle class="text-2xl lg:text-3xl font-bold tracking-tight text-[var(--color-text)]" style="font-family: var(--font-heading);">
        You have {days} days to file your {practiceArea.toLowerCase()} claim.
      </DialogTitle>

      <DialogDescription class="mt-3 text-base text-[var(--color-text-secondary)] leading-relaxed">
        The Fair Work Commission enforces a strict {days}-day deadline from the date of dismissal. Missing this deadline could mean losing your right to compensation entirely. A free consultation takes just 15 minutes.
      </DialogDescription>
    </DialogHeader>

    <DialogFooter class="mt-6 flex-row justify-start gap-3">
      <SiteButton href="/contact" size="sm">
        Free consultation
      </SiteButton>
      <SiteButton href="tel:0295551234" variant="outline" size="sm">
        Call (02) 9555 1234
      </SiteButton>
    </DialogFooter>
  </DialogContent>
</Dialog>

<script>
  function initExitIntent() {
    const dialogWrapper = document.getElementById('exit-intent-dialog');
    if (!dialogWrapper) return;

    const SESSION_KEY = 'exit-intent-shown';

    // Only show once per session
    if (sessionStorage.getItem(SESSION_KEY)) return;

    function showModal() {
      sessionStorage.setItem(SESSION_KEY, '1');
      dialogWrapper.dispatchEvent(new CustomEvent('dialog:open'));
      document.removeEventListener('mouseout', handleMouseOut);
    }

    function handleMouseOut(e: MouseEvent) {
      // Trigger when cursor moves above the viewport (toward address bar / tabs)
      if (e.clientY <= 0) {
        showModal();
      }
    }

    // Desktop: exit intent on mouse leaving viewport top
    document.addEventListener('mouseout', handleMouseOut);

    // Mobile: trigger on back button / visibility change after 30s
    setTimeout(() => {
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden' && !sessionStorage.getItem(SESSION_KEY)) {
          sessionStorage.setItem(SESSION_KEY, '1');
        }
      }, { once: true });
    }, 30000);
  }

  initExitIntent();
  document.addEventListener('astro:after-swap', initExitIntent);
</script>
